{ "type": "Feature", "properties": { "gid": 16, "titlu": "All things సమం - Daria Minina - ZIDART 2020 DomiNow", "layer": "ZIDART 2020 DomiNow", "nume_artist": "Daria Minina (Rusia)", "suprafata_lucrare": "400 mp", "adresa_lucrare": "strada Logofăt Tăutu nr.8, Bacău", "descriere": "Descriere lucrare: \"All things సమం\" este o reprezentare a starii de echilibru, în toate aspectele. Construită în jurul a două culori și două personaje ce se completează și se află în armonie. EN Artwork description: \"All things సమం\" is an expression of balance, in all its form. Structured around two colours and two characters that complete each other and live in harmony.", "nr_imagini": 6, "image_1": "https://services.geo-spatial.org/data/florin/zidart/e9da9f0b0a/image_001.jpg", "image_2": "https://services.geo-spatial.org/data/florin/zidart/e9da9f0b0a/image_002.jpg", "image_3": "https://services.geo-spatial.org/data/florin/zidart/e9da9f0b0a/image_003.jpg", "image_4": "https://services.geo-spatial.org/data/florin/zidart/e9da9f0b0a/image_004.jpg", "image_5": "https://services.geo-spatial.org/data/florin/zidart/e9da9f0b0a/image_005.jpg", "image_6": "https://services.geo-spatial.org/data/florin/zidart/e9da9f0b0a/image_006.jpg", "image_7": null, "image_8": null }, "geometry": { "type": "Point", "coordinates": [ 26.913351746291057, 46.570394421690886 ] } },
{ "type": "Feature", "properties": { "gid": 17, "titlu": "Fragile Tranquility - James Cochran - ZIDART 2020 DomiNow", "layer": "ZIDART 2020 DomiNow", "nume_artist": "James Cochran (Australia)", "suprafata_lucrare": "280 mp", "adresa_lucrare": "strada Vasile Alecsandri nr.31, Bacău", "descriere": "Descriere lucrare: \"Fragile Tranquility\" sau \"Tranquilitate fragilă\" este reprezentarea unei stări şi a unui spațiu de linişte şi pace în opoziție cu haosul și aglomerarea urbană. EN Artwork description: \"Fragile Tranquility\" portrays a state and space of peace and calm in opposition to the urban chaos and crowding.", "nr_imagini": 5, "image_1": "https://services.geo-spatial.org/data/florin/zidart/8fb43b9176/image_001.jpg", "image_2": "https://services.geo-spatial.org/data/florin/zidart/8fb43b9176/image_002.jpg", "image_3": "https://services.geo-spatial.org/data/florin/zidart/8fb43b9176/image_003.jpg", "image_4": "https://services.geo-spatial.org/data/florin/zidart/8fb43b9176/image_004.jpg", "image_5": "https://services.geo-spatial.org/data/florin/zidart/8fb43b9176/image_005.jpg", "image_6": null, "image_7": null, "image_8": null }, "geometry": { "type": "Point", "coordinates": [ 26.910104212591262, 46.566921390743941 ] } },
{ "type": "Feature", "properties": { "gid": 18, "titlu": "Povestea unei secunde - Gijs Vanhee - ZIDART 2020 DomiNow", "layer": "ZIDART 2020 DomiNow", "nume_artist": "Gijs Vanhee (Belgia)", "suprafata_lucrare": "230 mp", "adresa_lucrare": "Calea Mărăşeşti nr.6, Bacău", "descriere": "Descriere lucrare: Povestea unei secunde. Această lucrare e o odă dedicată puterii naturii și stării de prezență. Felul în care am construit-o amintește de modul în care timpul trece și viețile noastre continuă. EN Artwork description: The story of a second. This work is an ode to the power of nature and the state of presence. The way it’s built reflects how time passes by and our lives go on.", "nr_imagini": 4, "image_1": "https://services.geo-spatial.org/data/florin/zidart/743285a58d/image_001.jpg", "image_2": "https://services.geo-spatial.org/data/florin/zidart/743285a58d/image_002.jpg", "image_3": "https://services.geo-spatial.org/data/florin/zidart/743285a58d/image_003.jpg", "image_4": "https://services.geo-spatial.org/data/florin/zidart/743285a58d/image_004.jpg", "image_5": null, "image_6": null, "image_7": null, "image_8": null }, "geometry": { "type": "Point", "coordinates": [ 26.930184886597728, 46.577428012242277 ] } },
{ "type": "Feature", "properties": { "gid": 19, "titlu": "Happiness - Daniel Eime - ZIDART 2020 DomiNow", "layer": "ZIDART 2020 DomiNow", "nume_artist": "Daniel Eime (Portugalia)", "suprafata_lucrare": "260 mp", "adresa_lucrare": "strada Energiei nr.6, Bacău", "descriere": "Descriere lucrare: \"Happiness\" este o celebrare a bucuriei și a copilăriei, însoțită de o expresie vizuală puternică și calmă. EN Artwork description: \"Happiness\" is a celebration of joy and childhood, rendered with a strong yet peaceful visual language.", "nr_imagini": 4, "image_1": "https://services.geo-spatial.org/data/florin/zidart/2a9044ad90/image_001.jpg", "image_2": "https://services.geo-spatial.org/data/florin/zidart/2a9044ad90/image_002.jpg", "image_3": "https://services.geo-spatial.org/data/florin/zidart/2a9044ad90/image_003.jpg", "image_4": "https://services.geo-spatial.org/data/florin/zidart/2a9044ad90/image_004.jpg", "image_5": null, "image_6": null, "image_7": null, "image_8": null }, "geometry": { "type": "Point", "coordinates": [ 26.935331809450387, 46.580560068151131 ] } },
{ "type": "Feature", "properties": { "gid": 20, "titlu": "Lumea magică a sportului - John Dot S - ZIDART 2021 Rises", "layer": "ZIDART 2021 Rises", "nume_artist": "John Dot S (România)", "suprafata_lucrare": "175 mp", "adresa_lucrare": "Str. Mircea Eliade nr. 1, Bacău", "descriere": "Descriere lucrare: Lucrarea reprezintă o revenire a umanitații, o revenire spre natură și o reîntoarcere la valorile morale și etice. EN Artwork description: The artwork shows the return of humanity, a return to nature and a comeback to moral and ethical values.", "nr_imagini": 5, "image_1": "https://services.geo-spatial.org/data/florin/zidart/0aa889aa5b/image_001.jpg", "image_2": "https://services.geo-spatial.org/data/florin/zidart/0aa889aa5b/image_002.jpg", "image_3": "https://services.geo-spatial.org/data/florin/zidart/0aa889aa5b/image_003.jpg", "image_4": "https://services.geo-spatial.org/data/florin/zidart/0aa889aa5b/image_004.jpg", "image_5": "https://services.geo-spatial.org/data/florin/zidart/0aa889aa5b/image_005.jpg", "image_6": null, "image_7": null, "image_8": null }, "geometry": { "type": "Point", "coordinates": [ 26.914094930886281, 46.570594527793235 ] } },
{ "type": "Feature", "properties": { "gid": 21, "titlu": "Astronomul - Mural Projekt - ZIDART 2021 Rises", "layer": "ZIDART 2021 Rises", "nume_artist": "Mural Projekt (Italia)", "suprafata_lucrare": "200 mp", "adresa_lucrare": "Str. Mircea Eliade nr. 17, Bacău", "descriere": "Descriere lucrare: O explorare a curiozității umane și a nevoii de a înțelege universul. EN Artwork description: An exploration of human curiosity and the need to understand the universe.", "nr_imagini": 5, "image_1": "https://services.geo-spatial.org/data/florin/zidart/241d5a6c33/image_001.jpg", "image_2": "https://services.geo-spatial.org/data/florin/zidart/241d5a6c33/image_002.jpg", "image_3": "https://services.geo-spatial.org/data/florin/zidart/241d5a6c33/image_003.jpg", "image_4": "https://services.geo-spatial.org/data/florin/zidart/241d5a6c33/image_004.jpg", "image_5": "https://services.geo-spatial.org/data/florin/zidart/241d5a6c33/image_005.jpg", "image_6": null, "image_7": null, "image_8": null }, "geometry": { "type": "Point", "coordinates": [ 26.913696889078243, 46.571413394462508 ] } },
